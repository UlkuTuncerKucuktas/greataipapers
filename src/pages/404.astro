---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const cat = [
  "   /\\_/\\          ",
  "  ( o.O )   ?     ",
  "   > ~ <          ",
  "  /|   |\\   ??   ",
  " (_|   |_)        ",
].join("\n");
---
<!doctype html>
<html lang="en">
    <head>
        <BaseHead title="404 - Lost Cat" description="Page not found" />
        <style>
            body {
                background: var(--bg);
                color: var(--text);
                margin: 0;
                font-family: 'Inter', -apple-system, sans-serif;
            }
            main {
                max-width: 720px;
                margin: 0 auto;
                padding: 4rem 1.5rem;
                text-align: center;
            }
            .cat-404 {
                font-family: 'Courier New', monospace;
                color: var(--green);
                font-size: 1.2rem;
                line-height: 1.5;
                white-space: pre;
                margin: 2rem 0;
                display: inline-block;
                font-weight: bold;
                text-shadow: 0 0 0.5px currentColor;
            }
            h1 {
                font-size: 5rem;
                margin: 0;
                font-weight: 800;
                letter-spacing: -3px;
                color: var(--text);
            }
            .subtitle {
                color: var(--text-muted);
                font-size: 1.1rem;
                margin: 0.25rem 0 0;
                font-style: italic;
            }
            .home-link {
                display: inline-block;
                margin-top: 0.5rem;
                color: var(--accent);
                text-decoration: none;
                font-size: 0.95rem;
                border: 1px solid var(--border);
                padding: 8px 24px;
                border-radius: 6px;
                transition: border-color 0.2s, color 0.2s;
            }
            .home-link:hover {
                border-color: var(--accent);
                color: var(--accent-hover);
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <h1>404</h1>
            <p class="subtitle">this page wandered off</p>
            <pre class="cat-404" set:text={cat} />
            <a class="home-link" href="/">take me home</a>
        </main>
        <Footer />
    </body>
</html>
