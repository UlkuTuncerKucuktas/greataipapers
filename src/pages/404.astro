---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const cat = [
  "  /\\_/\\",
  " ( o.O )  ?",
  "  > ~ <",
  " /|   |\\",
  "(_|   |_)",
].join("\n");
---
<!doctype html>
<html lang="en">
    <head>
        <BaseHead title="404 - Lost Cat" description="Page not found" />
        <style>
            body {
                background: var(--bg);
                color: var(--text);
                margin: 0;
                font-family: 'Inter', -apple-system, sans-serif;
            }
            main {
                max-width: 720px;
                margin: 0 auto;
                padding: 4rem 1.5rem;
                text-align: center;
            }
            .cat-404 {
                font-family: 'Courier New', monospace;
                color: var(--green);
                font-size: 1rem;
                line-height: 1.4;
                white-space: pre;
                margin: 2rem 0;
                display: inline-block;
            }
            h1 { font-size: 3rem; margin: 0 0 0.5rem; }
            .subtitle {
                color: var(--text-muted);
                font-size: 1.05rem;
                margin: 0 0 1rem;
                font-style: italic;
            }
            .home-link {
                color: var(--accent);
                text-decoration: none;
                font-size: 0.95rem;
                border-bottom: 1px solid var(--border);
                padding-bottom: 2px;
                transition: border-color 0.2s;
            }
            .home-link:hover { border-color: var(--accent); }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <h1>404</h1>
            <p class="subtitle">this page wandered off</p>
            <pre class="cat-404" set:text={cat} />
            <p><a class="home-link" href="/">take me home</a></p>
        </main>
        <Footer />
    </body>
</html>
