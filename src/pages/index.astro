---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            *, *::before, *::after {
                box-sizing: border-box;
            }

            :root {
                --accent: #8B83E0;
                --accent-hover: #AFA9EC;
                --bg-page: #0F1117;
                --bg-surface: #1A1D2E;
                --bg-elevated: #222338;
                --text-primary: #F0EEF6;
                --text-secondary: #D1D1D8;
                --text-tertiary: #8E8EA0;
                --border: #252640;
            }

            body {
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
                background: var(--bg-page);
                color: var(--text-primary);
                margin: 0;
                overflow-x: hidden;
            }

            main {
                width: 100%;
                max-width: 720px;
                margin: 0 auto;
                padding: 0 1.5rem;
            }

            .hero {
                padding: 3rem 0 2rem;
                border-bottom: 1px solid var(--border);
            }

            .hero h1 {
                font-size: clamp(1.5rem, 5vw, 2rem);
                font-weight: 600;
                line-height: 1.3;
                letter-spacing: -0.5px;
                margin: 0 0 0.75rem;
                color: var(--text-primary);
            }

            .ascii-art {
                font-family: 'Courier New', monospace;
                color: #4ADE80;
                font-size: 0.75rem;
                line-height: 1.4;
                margin-top: 1.5rem;
                background: none;
                border: none;
                padding: 0;
                overflow-x: auto;
                white-space: pre;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
            }

            .section-label {
                font-size: 0.75rem;
                color: var(--text-tertiary);
                letter-spacing: 1.5px;
                text-transform: uppercase;
                margin: 2rem 0 1rem;
            }

            .post-list {
                list-style: none;
                padding: 0;
                margin: 0;
            }

            .post-item {
                padding: 1.25rem 0;
                border-bottom: 1px solid var(--border);
            }

            .post-item:last-child {
                border-bottom: none;
            }

            .post-link {
                text-decoration: none;
                display: block;
            }

            .post-header {
                display: flex;
                justify-content: space-between;
                align-items: baseline;
                gap: 1rem;
                margin-bottom: 6px;
            }

            .post-title {
                font-size: 1.15rem;
                font-weight: 500;
                color: var(--text-primary);
                margin: 0;
                line-height: 1.4;
                transition: color 0.2s;
            }

            .post-link:hover .post-title {
                color: var(--accent-hover);
            }

            .post-date {
                font-size: 0.8rem;
                color: var(--text-tertiary);
                white-space: nowrap;
            }

            .post-description {
                font-size: 0.95rem;
                color: var(--text-secondary);
                line-height: 1.6;
                margin: 0;
            }

            .empty-state {
                text-align: center;
                padding: 3rem 0;
                color: var(--text-secondary);
            }

            .empty-state p {
                font-size: 1rem;
                margin: 0.5rem 0;
            }

            @media (max-width: 600px) {
                .post-header {
                    flex-direction: column;
                    gap: 0.25rem;
                }

                .post-title {
                    font-size: 1rem;
                }

                .hero {
                    padding: 2rem 0 1.5rem;
                }

                .ascii-art {
                    font-size: 0.55rem;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <section class="hero">
                <h1>Dissecting the papers that shape AI</h1>
                <pre class="ascii-art">{String.raw`                                          z
                                         z
      /\\_/\\  ______       /\\_/\\  ______  Z
     ( o.o )|      |     ( -.- )|      |
      > ^ < |  AI  |      > ^ < |  ML  |
     /     \\|______|     /     \\|______|
    (__|  |__)          (__|  |__)

         papers worth reading.`}</pre>
            </section>

            <p class="section-label">Latest reviews</p>

            {posts.length > 0 ? (
                <ul class="post-list">
                    {posts.map((post) => (
                        <li class="post-item">
                            <a class="post-link" href={`/blog/${post.id}/`}>
                                <div class="post-header">
                                    <h2 class="post-title">{post.data.title}</h2>
                                    <span class="post-date">
                                        {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                                            month: 'short',
                                            year: 'numeric',
                                        })}
                                    </span>
                                </div>
                                {post.data.description && (
                                    <p class="post-description">{post.data.description}</p>
                                )}
                            </a>
                        </li>
                    ))}
                </ul>
            ) : (
                <div class="empty-state">
                    <p>First review coming soon.</p>
                </div>
            )}
        </main>
        <Footer />
    </body>
</html>
