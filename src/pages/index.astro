---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const cats = [
  "                                       z  ",
  "                                      z   ",
  "     /\\_/\\  ______      /\\_/\\  ______ Z  ",
  "    ( o.o )|      |    ( -.- )|      |    ",
  "     > ^ < |  AI  |     > ^ < |  ML  |   ",
  "    /     \\|______|    /     \\|______|   ",
  "   (__|  |__)         (__|  |__)          ",
].join("\n");
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            *, *::before, *::after {
                box-sizing: border-box;
            }

            :root {
                --accent: #8B83E0;
                --accent-hover: #AFA9EC;
                --bg-page: #110F0E;
                --bg-surface: #1A1816;
                --text-primary: #F0EEF6;
                --text-secondary: #D1D1D8;
                --text-tertiary: #8E8EA0;
                --border: #2A2520;
                --green: #4ADE80;
            }

            body {
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
                background: var(--bg-page);
                color: var(--text-primary);
                margin: 0;
                overflow-x: hidden;
            }

            main {
                width: 100%;
                max-width: 720px;
                margin: 0 auto;
                padding: 0 1.5rem;
            }

            .hero {
                padding: 3rem 0 2rem;
                border-bottom: 1px solid var(--border);
            }

            .hero h1 {
                font-size: clamp(1.5rem, 5vw, 2rem);
                font-weight: 600;
                line-height: 1.3;
                letter-spacing: -0.5px;
                margin: 0 0 0.5rem;
                color: var(--text-primary);
            }

            .hero-sub {
                font-size: 0.95rem;
                color: var(--text-tertiary);
                margin: 0 0 1.5rem;
                font-style: italic;
            }

            .ascii-box {
                display: flex;
                flex-direction: column;
                align-items: center;
                margin-top: 1rem;
                padding: 1.5rem 0;
                background: radial-gradient(ellipse at center bottom, transparent 0%, transparent 100%);
                border-radius: 12px;
            }
            .ascii-art {
                font-family: 'Courier New', monospace;
                color: var(--green);
                font-size: 0.75rem;
                line-height: 1.3;
                background: none;
                border: none;
                padding: 0;
                margin: 0;
                overflow-x: auto;
                white-space: pre;
            }

            .ascii-tagline {
                font-family: 'Courier New', monospace;
                color: var(--green);
                font-size: 0.8rem;
                margin-top: 0.75rem;
                opacity: 0.9;
            }

            .memorial {
                font-size: 0.7rem;
                color: var(--text-tertiary);
                margin-top: 1rem;
                font-style: italic;
                opacity: 0.6;
            }

            .section-label {
                font-size: 0.75rem;
                color: var(--text-tertiary);
                letter-spacing: 1.5px;
                text-transform: uppercase;
                margin: 2.5rem 0 1rem;
            }

            .post-list {
                list-style: none;
                padding: 0;
                margin: 0;
            }

            .post-item {
                padding: 1.5rem 0;
                border-bottom: 1px solid var(--border);
                transition: background 0.2s;
            }

            .post-item:last-child {
                border-bottom: none;
            }

            .post-link {
                text-decoration: none;
                display: block;
            }

            .post-header {
                display: flex;
                justify-content: space-between;
                align-items: baseline;
                gap: 1rem;
                margin-bottom: 8px;
            }

            .post-title {
                font-size: 1.15rem;
                font-weight: 500;
                color: var(--text-primary);
                margin: 0;
                line-height: 1.4;
                transition: color 0.2s;
            }

            .post-link:hover .post-title {
                color: var(--accent-hover);
            }

            .post-date {
                font-size: 0.8rem;
                color: var(--text-tertiary);
                white-space: nowrap;
            }

            .post-description {
                font-size: 0.9rem;
                color: var(--text-secondary);
                line-height: 1.6;
                margin: 0;
                opacity: 0.85;
            }

            .empty-state {
                text-align: center;
                padding: 3rem 0;
                color: var(--text-secondary);
            }

            .empty-state p {
                font-size: 1rem;
                margin: 0.5rem 0;
            }

            @media (max-width: 600px) {
                .post-header {
                    flex-direction: column;
                    gap: 0.25rem;
                }

                .post-title {
                    font-size: 1rem;
                }

                .hero {
                    padding: 2rem 0 1.5rem;
                }

                .ascii-art {
                    font-size: 0.5rem;
                }

                .ascii-tagline {
                    font-size: 0.7rem;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <section class="hero">
                <h1>Dissecting the papers that shape AI</h1>
                <div class="ascii-box">
                    <pre class="ascii-art" set:text={cats} />
                    <span class="ascii-tagline">papers worth reading.</span>
                    <span class="memorial">in loving memory of paperswithcode ♡</span>
                </div>
            </section>

            <p class="section-label">Latest reviews</p>

            {posts.length > 0 ? (
                <ul class="post-list">
                    {posts.map((post) => (
                        <li class="post-item">
                            <a class="post-link" href={`/blog/${post.id}/`}>
                                <div class="post-header">
                                    <h2 class="post-title">{post.data.title}</h2>
                                    <span class="post-date">
                                        {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                                            month: 'short',
                                            year: 'numeric',
                                        })}
                                    </span>
                                </div>
                                {post.data.description && (
                                    <p class="post-description">{post.data.description}</p>
                                )}
                            </a>
                        </li>
                    ))}
                </ul>
            ) : (
                <div class="empty-state">
                    <p>First review coming soon.</p>
                </div>
            )}
        </main>
        <Footer />
    </body>
</html>
