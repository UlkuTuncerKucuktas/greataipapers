---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const cats = [
  "                                       z  ",
  "                                      z   ",
  "     /\\_/\\  ______      /\\_/\\  ______ Z  ",
  "    ( o.o )|      |    ( -.- )|      |    ",
  "     > ^ < |  AI  |     > ^ < |  ML  |   ",
  "    /     \\|______|    /     \\|______|   ",
  "   (__|  |__)         (__|  |__)          ",
].join("\n");
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            *, *::before, *::after {
                box-sizing: border-box;
            }

            :root {
                --accent: var(--accent);
                --accent-hover: var(--accent-hover);
                --bg-page: var(--bg);
                --bg-surface: var(--bg-surface);
                --text-primary: var(--text);
                --text-secondary: var(--text-body);
                --text-tertiary: var(--text-muted);
                --border: var(--border);
                --green: #4ADE80;
            }

            body {
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
                background: var(--bg-page);
                color: var(--text-primary);
                margin: 0;
                overflow-x: hidden;
            }

            main {
                width: 100%;
                max-width: 720px;
                margin: 0 auto;
                padding: 0 1.5rem;
            }

            .hero {
                padding: 3rem 0 2rem;
                border-bottom: 1px solid var(--border);
            }

            .hero h1 {
                font-size: clamp(1.5rem, 5vw, 2rem);
                font-weight: 600;
                line-height: 1.3;
                letter-spacing: -0.5px;
                margin: 0 0 0.5rem;
                color: var(--text-primary);
            }

            .hero-sub {
                font-size: 0.95rem;
                color: var(--text-tertiary);
                margin: 0 0 1.5rem;
                font-style: italic;
            }

            
            .ascii-box {
                position: relative;
            }

            .zzz-container {
                position: absolute;
                right: calc(50% - 11rem);
                top: 0.5rem;
            }

            .zzz {
                position: absolute;
                font-family: 'Courier New', monospace;
                color: var(--green);
                opacity: 0;
                animation: floatZ 3s ease-out infinite;
            }

            .zzz1 {
                font-size: 0.65rem;
                animation-delay: 0s;
                right: 0;
            }
            .zzz2 {
                font-size: 0.75rem;
                animation-delay: 1s;
                right: 0.5rem;
            }
            .zzz3 {
                font-size: 0.9rem;
                animation-delay: 2s;
                right: 1rem;
            }

            @keyframes floatZ {
                0% {
                    opacity: 0;
                    transform: translateY(0px);
                }
                15% {
                    opacity: 0.8;
                }
                80% {
                    opacity: 0.3;
                }
                100% {
                    opacity: 0;
                    transform: translateY(-35px);
                }
            }

            .ascii-box-REPLACED {
                display: flex;
                flex-direction: column;
                align-items: center;
                margin-top: 1rem;
                padding: 1.5rem 0;
                background: radial-gradient(ellipse at center bottom, transparent 0%, transparent 100%);
                border-radius: 12px;
            }
            .ascii-art {
                font-family: 'Courier New', monospace;
                color: var(--green);
                font-size: 0.75rem;
                line-height: 1.3;
                background: none;
                border: none;
                padding: 0;
                margin: 0;
                overflow-x: auto;
                white-space: pre;
            }

            .ascii-tagline {
                font-family: 'Courier New', monospace;
                color: var(--green);
                font-size: 0.8rem;
                margin-top: 0.75rem;
                opacity: 0.9;
            }

            .memorial {
                font-size: 0.7rem;
                color: var(--text-tertiary);
                margin-top: 1rem;
                font-style: italic;
                opacity: 0.6;
            }

            .section-label {
                font-size: 0.75rem;
                color: var(--text-tertiary);
                letter-spacing: 1.5px;
                text-transform: uppercase;
                margin: 2.5rem 0 1rem;
            }

            .post-list {
                list-style: none;
                padding: 0;
                margin: 0;
            }

            .post-item {
                padding: 1.5rem 0;
                border-bottom: 1px solid var(--border);
                transition: background 0.2s;
            }

            .post-item:last-child {
                border-bottom: none;
            }

            .post-link {
                text-decoration: none;
                display: block;
            }

            .post-header {
                display: flex;
                justify-content: space-between;
                align-items: baseline;
                gap: 1rem;
                margin-bottom: 8px;
            }

            .post-title {
                font-size: 1.15rem;
                font-weight: 500;
                color: var(--text-primary);
                margin: 0;
                line-height: 1.4;
                transition: color 0.2s;
            }

            .post-link:hover .post-title {
                color: var(--accent-hover);
            }

            .post-date {
                font-size: 0.8rem;
                color: var(--text-tertiary);
                white-space: nowrap;
            }

            .post-description {
                font-size: 0.9rem;
                color: var(--text-secondary);
                line-height: 1.6;
                margin: 0;
                opacity: 0.85;
            }

            .search-section {
                display: flex;
                align-items: baseline;
                justify-content: space-between;
                gap: 1rem;
                margin-top: 2.5rem;
                margin-bottom: 1rem;
            }
            .search-section .section-label {
                margin: 0;
            }
            .search-input {
                background: var(--bg-surface);
                border: 1px solid var(--border);
                border-radius: 6px;
                padding: 6px 12px;
                color: var(--text);
                font-size: 0.8rem;
                width: 180px;
                outline: none;
                transition: border-color 0.2s;
                font-family: inherit;
            }
            .search-input::placeholder {
                color: var(--text-muted);
            }
            .search-input:focus {
                border-color: var(--accent);
            }
            .empty-state {
                text-align: center;
                padding: 3rem 0;
                color: var(--text-secondary);
            }

            .empty-state p {
                font-size: 1rem;
                margin: 0.5rem 0;
            }

            @media (max-width: 600px) {
                .post-header {
                    flex-direction: column;
                    gap: 0.25rem;
                }

                .post-title {
                    font-size: 1rem;
                }

                .hero {
                    padding: 2rem 0 1.5rem;
                }

                .ascii-art {
                    font-size: 0.5rem;
                }

                .ascii-tagline {
                    font-size: 0.7rem;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <section class="hero">
                <h1>Dissecting the papers that shape AI</h1>
                <div class="ascii-box">
                    <pre class="ascii-art" set:text={cats} />
                    <div class="zzz-container">
                        <span class="zzz zzz1">z</span>
                        <span class="zzz zzz2">z</span>
                        <span class="zzz zzz3">Z</span>
                    </div>
                    <span class="ascii-tagline">papers worth reading.</span>
                    <span class="memorial">in loving memory of paperswithcode ♡</span>
                </div>
            </section>

            <div class="search-section">
                <p class="section-label">Latest reviews</p>
                <input type="text" id="search" placeholder="search posts..." class="search-input" />
            </div>

            {posts.length > 0 ? (
                <ul class="post-list">
                    {posts.map((post) => (
                        <li class="post-item">
                            <a class="post-link" href={`/blog/${post.id}/`}>
                                <div class="post-header">
                                    <h2 class="post-title">{post.data.title}</h2>
                                    <span class="post-date">
                                        {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                                            month: 'short',
                                            year: 'numeric',
                                        })}
                                    </span>
                                </div>
                                {post.data.description && (
                                    <p class="post-description">{post.data.description}</p>
                                )}
                            </a>
                        </li>
                    ))}
                </ul>
            ) : (
                <div class="empty-state">
                    <p>First review coming soon.</p>
                </div>
            )}
        </main>
        <Footer />
    </body>


<script>
  const pre = document.querySelector('.ascii-art');
  if (pre) {
    setInterval(() => {
      const txt = pre.textContent;
      if (txt.includes('o.o')) {
        pre.textContent = txt.replace('o.o', '-.-');
        setTimeout(() => {
          pre.textContent = pre.textContent.replace('-.-', 'o.o');
        }, 200);
      }
    }, 4000);
  }
</script>
</html>

