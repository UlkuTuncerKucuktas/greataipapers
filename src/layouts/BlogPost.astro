---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				width: 100%;
				height: auto;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--text-body);
			}
			.prose :global(h1),
			.prose :global(h2),
			.prose :global(h3),
			.prose :global(h4) {
				color: var(--text);
			}
			.prose :global(strong) {
				color: var(--text);
			}
			.prose :global(code) {
				background: var(--bg-code);
				padding: 2px 6px;
				border-radius: 4px;
				color: var(--accent);
			}
			.prose :global(pre) {
				background: var(--bg-surface);
				border: 1px solid var(--border);
				border-radius: 8px;
				padding: 1rem;
			}
			.prose :global(blockquote) {
				border-left: 3px solid var(--accent);
				padding-left: 1rem;
				color: var(--text-body);
			}
            .prose :global(.katex-display) {
                overflow-x: auto;
                overflow-y: hidden;
                padding: 0.5rem 0;
                -webkit-overflow-scrolling: touch;
            }
            .prose :global(.katex) {
                font-size: 0.95em;
            }			.prose :global(hr) {
				border: none;
				border-top: 1px solid var(--border);
			}
                        .prose :global(img) {
                                max-width: 100%;
     				height: auto;
    				border-radius: 8px;
    				margin: 1.5rem 0;
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				color: var(--text);
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--text-faint);
			}
			.last-updated-on {
				font-style: italic;
			}
			.title {
				position: relative;
			}
			.title::before, .title::after {
				font-family: 'Courier New', monospace;
				color: var(--green);
				font-size: 0.65rem;
				font-weight: bold;
				text-shadow: 0 0 0.5px currentColor;
				line-height: 1.3;
				white-space: pre;
				opacity: 0.4;
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				display: none;
			}
			.title::before {
				content: "/\\_/\\\A( o.o )\A > ^ <";
				left: -5.5rem;
			}
			.title::after {
				content: "/\\_/\\\A( -.- )\A > ^ <";
				right: -5.5rem;
			}
			.title::before, .title::after {
				display: block;
			}
			@media (max-width: 899px) {
				.title::before {
					position: static;
					transform: none;
					display: block;
					text-align: center;
					margin-bottom: 0.5rem;
				}
				.title::after {
					display: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width="1020" height="510" src={heroImage.src || heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
								<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
